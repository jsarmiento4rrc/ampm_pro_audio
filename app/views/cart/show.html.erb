<h1>Your Shopping Cart</h1>

<% if session[:cart].empty? %>
  <p>Your cart is currently empty.</p>
  <%= link_to "Continue Shopping", root_path %>
<% else %>
  <table style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
    <thead>
      <tr style="border-bottom: 2px solid #333; text-align: left;">
        <th style="padding: 10px;">Product</th>
        <th style="padding: 10px;">Price</th>
        <th style="padding: 10px;">Quantity</th>
        <th style="padding: 10px;">Subtotal</th>
        <th style="padding: 10px;">Action</th>
      </tr>
    </thead>
    <tbody>
      <% cart_total = 0 %>
      <% @cart_items.each do |product| %>
        <% quantity = session[:cart][product.id.to_s] %>
        <% subtotal = product.price * quantity %>
        <% cart_total += subtotal %>
        
        <tr style="border-bottom: 1px solid #ddd;">
          <td style="padding: 10px;">
            <%= link_to product.product_name, product %>
          </td>
          <td style="padding: 10px;"><%= number_to_currency(product.price) %></td>
          
          <td style="padding: 10px;">
            <%= form_with url: cart_update_path, method: :post, style: "display: inline-block;" do |f| %>
              <%= f.hidden_field :product_id, value: product.id %>
              <%= f.number_field :quantity, value: quantity, min: 1, style: "width: 60px;" %>
              <%= f.submit "Update" %>
            <% end %>
          </td>
          
          <td style="padding: 10px;"><%= number_to_currency(subtotal) %></td>
          
          <td style="padding: 10px;">
            <%= form_with url: cart_remove_path, method: :delete, style: "display: inline-block;" do |f| %>
              <%= f.hidden_field :product_id, value: product.id %>
              <%= f.submit "Remove", style: "color: red;" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <h2 style="text-align: right;">Total: <%= number_to_currency(cart_total) %></h2>

  <div style="margin-top: 20px;">
    <%= link_to "Continue Shopping", root_path, style: "margin-right: 15px;" %>
    <button disabled>Checkout (Next Phase)</button>
  </div>
<% end %>