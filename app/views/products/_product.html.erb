<div class="column is-one-quarter-desktop is-half-tablet is-full-mobile">
  <div class="card is-flex is-flex-direction-column" style="height: 100%;">
    
    <% if product.image.attached? %>
      <div class="card-image">
        <figure class="image is-4by3">
          <%= image_tag product.image, style: "object-fit: contain; padding: 15px;" %>
        </figure>
      </div>
    <% end %>

    <div class="card-content is-flex-grow-1 is-flex is-flex-direction-column is-justify-content-space-between">
      <div>
        <p class="is-size-7 has-text-grey is-uppercase mb-2"><%= product.category.category_name %></p>
        <p class="title is-5 mb-4"><%= link_to product.product_name, product, class: "has-text-dark" %></p>
      </div>
      <p class="title is-4 has-text-primary mt-auto"><%= number_to_currency(product.price) %></p>
    </div>
    
  </div>
</div>